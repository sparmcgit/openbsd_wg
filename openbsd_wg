#!/bin/bash
# Set up a point-to-point WireGuard tunnel between two OpenBSD servers,
# one wg0 interface on each end, persisted via /etc/hostname.wg0.
#
# Usage:
#   openbsd_wg [user@]<server1> [user@]<server2>

set -euo pipefail

WG_IF=wg0
WG_PORT=51820
WG_PREFIX=24
WG_ADDR1=192.168.5.1
WG_ADDR2=192.168.5.2

usage() {
	cat <<-EOF
	usage: openbsd_wg [user@]<server1> [user@]<server2>

	Sets up a point-to-point WireGuard tunnel between two OpenBSD
	servers: $WG_IF on server1 gets $WG_ADDR1/$WG_PREFIX, $WG_IF on server2
	gets $WG_ADDR2/$WG_PREFIX, peered to each other over UDP port $WG_PORT.
	Requires root ssh access to both servers (or pass user@host).
	EOF
}

[ "$#" -eq 2 ] || { usage; exit 1; }

SERVER1="$1"
SERVER2="$2"
ENDPOINT1="${SERVER1#*@}"
ENDPOINT2="${SERVER2#*@}"

# Run a fixed, already-literal command on a remote host under /bin/bash --
# root's default shell on OpenBSD is ksh.
remote() {
	local host="$1" cmd="$2"
	ssh "$host" "/bin/bash -c '$cmd'"
}

# Install wireguard-tools if missing (needed for wg genkey/pubkey; the wg0
# interface itself is native OpenBSD wg(4), no userland driver needed), and
# print this host's private key followed by its public key. The private
# key's only persistent home is the wgkey line in /etc/hostname.$WG_IF
# (ifconfig's wgkey directive needs the literal key value, not a path) --
# reused from there if it already exists so re-runs are idempotent,
# otherwise generated fresh via genkey|pubkey with no key material ever
# touching disk before it's embedded there.
ensure_keys() {
	local host="$1"
	ssh "$host" "/bin/bash -s" <<-EOF
	set -e
	command -v wg >/dev/null 2>&1 || pkg_add -I wireguard-tools 1>&2
	if [ -f /etc/hostname.$WG_IF ] && grep -q '^wgkey ' /etc/hostname.$WG_IF; then
		priv=\$(awk '/^wgkey /{print \$2}' /etc/hostname.$WG_IF)
	else
		priv=\$(wg genkey)
	fi
	echo "\$priv"
	echo "\$priv" | wg pubkey
	EOF
}

# Print the wgpsk value from a host's existing wgpeer line in
# /etc/hostname.$WG_IF, if any; prints nothing if there's no file or no
# wgpsk field yet.
read_psk() {
	local host="$1"
	ssh "$host" "/bin/bash -s" <<-EOF
	awk '/^wgpeer /{for(i=1;i<=NF;i++) if (\$i=="wgpsk") print \$(i+1)}' /etc/hostname.$WG_IF 2>/dev/null || true
	EOF
}

# Generate (or reuse) the single preshared key shared by both peers. Reused
# from either host's existing wgpeer wgpsk field first, so re-runs are
# idempotent; only generated fresh via `wg genpsk` on server1 if neither
# host has one yet. By the time this runs, ensure_keys has already made
# sure wireguard-tools (and thus wg genpsk) is installed on server1.
ensure_psk() {
	local host1="$1" host2="$2"
	local psk
	psk="$(read_psk "$host1")"
	[ -n "$psk" ] || psk="$(read_psk "$host2")"
	[ -n "$psk" ] || psk="$(ssh "$host1" "/bin/bash -c 'wg genpsk'")"
	echo "$psk"
}

# Write /etc/hostname.$WG_IF on a host, backing up any existing one first.
write_hostname_if() {
	local host="$1" addr="$2" own_privkey="$3" peer_pubkey="$4" peer_endpoint="$5" peer_aip="$6" psk="$7"

	ssh "$host" "/bin/bash -s" <<-EOF
	set -e
	if [ -f /etc/hostname.$WG_IF ]; then
		cp -p /etc/hostname.$WG_IF /etc/hostname.$WG_IF.bak.\$(date +%Y%m%d%H%M%S)
	fi
	EOF

	local content
	content=$(cat <<-EOF
	wgkey $own_privkey
	wgport $WG_PORT
	wgpeer $peer_pubkey wgendpoint $peer_endpoint $WG_PORT wgpsk $psk wgaip $peer_aip
	inet $addr/$WG_PREFIX
	up
	EOF
	)

	ssh "$host" "/bin/bash -c 'cat > /etc/hostname.$WG_IF && chmod 600 /etc/hostname.$WG_IF'" <<< "$content"
}

echo "==> generating/collecting WireGuard keys"
{ read -r PRIV1; read -r PUB1; } < <(ensure_keys "$SERVER1")
{ read -r PRIV2; read -r PUB2; } < <(ensure_keys "$SERVER2")
echo "    $ENDPOINT1 pubkey: $PUB1"
echo "    $ENDPOINT2 pubkey: $PUB2"

echo "==> generating/collecting preshared key"
PSK=$(ensure_psk "$SERVER1" "$SERVER2")

echo "==> writing /etc/hostname.$WG_IF on both servers"
write_hostname_if "$SERVER1" "$WG_ADDR1" "$PRIV1" "$PUB2" "$ENDPOINT2" "$WG_ADDR2/32" "$PSK"
write_hostname_if "$SERVER2" "$WG_ADDR2" "$PRIV2" "$PUB1" "$ENDPOINT1" "$WG_ADDR1/32" "$PSK"

echo "==> bringing up $WG_IF on both servers"
remote "$SERVER1" "sh /etc/netstart $WG_IF"
remote "$SERVER2" "sh /etc/netstart $WG_IF"

echo "==> verifying tunnel connectivity"
if ssh "$SERVER1" "/bin/bash -c 'ping -c 2 -w 5 $WG_ADDR2'" >/dev/null 2>&1; then
	echo "    OK: $ENDPOINT1 can reach $WG_ADDR2 over $WG_IF"
else
	echo "    FAILED: $ENDPOINT1 cannot reach $WG_ADDR2 over $WG_IF -- check firewall/pf rules for UDP $WG_PORT between the two servers" >&2
	exit 1
fi
